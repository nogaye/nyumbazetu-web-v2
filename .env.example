# Supabase Configuration
# Copy this file to .env.local and fill in your actual values
# Get these values from your Supabase project dashboard: https://app.supabase.com
# Settings > API > Project URL and API keys

# Required: Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Required: Your Supabase anon/public key (for client-side operations and Supabase Auth)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional but recommended: Service role key (for server-side operations, bypasses RLS)
# Get this from Settings > API > service_role key (keep this secret!)
# Never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: App URL for auth redirects (e.g. password reset, OAuth callback).
# If unset, redirect URLs are derived from request origin or VERCEL_URL.
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Optional: Intercom messenger (customer chat/support)
# Get your App ID from https://app.intercom.com → Settings → Installation
NEXT_PUBLIC_INTERCOM_APP_ID=your-intercom-app-id

# Optional: OpenAI API key for seed script (same-house Kenyan property images via DALL·E 3)
# Get your key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
